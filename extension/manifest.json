{
  "manifest_version": 3,
  "name": "CB Link",
  "version": "1.0.0",
  "description": "Chrome ブラウザおよび PWA の利用時間を監視し、保護者へリアルタイムに共有する拡張機能",
  "permissions": ["tabs", "storage", "alarms", "idle"],
  "host_permissions": ["http://localhost/*", "https://*.cloudfunctions.net/*"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
