# =============================================================================
# 本番環境用 .env テンプレート
# 実際の Firebase プロジェクトに接続する場合に使用。
# このファイルをコピーして mobile/.env にリネームし、値を埋めてください。
# =============================================================================

# Emulator 接続フラグ（本番では false または未設定）
EXPO_PUBLIC_USE_EMULATOR=false

# Firebase 設定
# 確認場所: Firebase Console → ⚙ プロジェクトの設定 → 全般
EXPO_PUBLIC_FIREBASE_API_KEY=<Firebase Console → プロジェクトの設定 → ウェブ API キー>
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=<project-id>
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=<project-id>.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<Firebase Console → プロジェクトの設定 → マイアプリ → 送信者ID>
EXPO_PUBLIC_FIREBASE_APP_ID=<Firebase Console → プロジェクトの設定 → マイアプリ → アプリID (1:xxx:web:xxx 形式)>

# Google SSO
# 確認場所: GCP Console → APIs & Services → Credentials → OAuth 2.0 Client IDs → Web client
EXPO_PUBLIC_WEB_CLIENT_ID=<Web Client ID>

# API Base URL (本番 Cloud Functions)
# <region> は Functions のデプロイリージョン (例: asia-northeast1, us-central1)
EXPO_PUBLIC_API_BASE_URL=https://<region>-<project-id>.cloudfunctions.net
