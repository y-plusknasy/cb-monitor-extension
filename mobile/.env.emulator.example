# =============================================================================
# Emulator 開発用設定
# Firebase Emulator に接続するための設定。Emulator 使用時は
# API Key / App ID 等はダミー値でも動作する。
# =============================================================================

# Emulator 接続フラグ（true で Emulator に接続）
EXPO_PUBLIC_USE_EMULATOR=true

# Emulator ホスト（DevContainer 内からは localhost でOK）
EXPO_PUBLIC_EMULATOR_HOST=localhost

# Firebase 設定（Emulator 使用時はダミー値でOK）
EXPO_PUBLIC_FIREBASE_API_KEY=fake-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost
EXPO_PUBLIC_FIREBASE_PROJECT_ID=cb-monitor-extension
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:fake

# Google SSO（Emulator の Auth では不要）
EXPO_PUBLIC_WEB_CLIENT_ID=

# API Base URL（Functions Emulator）
EXPO_PUBLIC_API_BASE_URL=http://localhost:5001/cb-monitor-extension/us-central1